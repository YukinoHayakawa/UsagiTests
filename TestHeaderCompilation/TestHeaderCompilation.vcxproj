<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="UnitTest|x64">
      <Configuration>UnitTest</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>18.0</VCProjectVersion>
    <ProjectGuid>{462ce001-aea9-42de-9468-c19f8cfaac38}</ProjectGuid>
    <RootNamespace>TestHeaderCompilation</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup>
    <!-- ConfigurationType MUST be specified BEFORE importing Microsoft.Cpp.props. -->
    <!-- Otherwise all projects become Application. -->
    <ConfigurationType>StaticLibrary</ConfigurationType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='UnitTest'">
    <ConfigurationType>Application</ConfigurationType>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <!-- But include paths must be defined AFTER importing Microsoft.Cpp.props. -->
  <PropertyGroup>
    <IncludePath>$(Usagi_IncludePaths);$(IncludePath)</IncludePath>
    <LibraryPath>$(Usagi_LibraryPaths);$(LibraryPath)</LibraryPath>
    <ExternalIncludeDirectories>$(ProjectDir);$(ExternalIncludeDirectories)</ExternalIncludeDirectories>
  </PropertyGroup>
  <ImportGroup Label="ExtensionSettings">
  </ImportGroup>
  <ImportGroup Label="Shared">
  </ImportGroup>
  <PropertyGroup Label="UserMacros">
  </PropertyGroup>
  <ItemGroup>
    <ClCompile Include="test.cpp" />
  </ItemGroup>
  <ItemGroup>
    <None Include=".gitignore" />
    <None Include="Generate-TestCpp.ps1" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
  <Target Name="GenerateTestCpp" BeforeTargets="ClCompile">
    <Message Importance="High" Text="Preprocessing test.cpp for single-header tests..." />
    <Exec Command="pwsh.exe -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\Generate-TestCpp.ps1&quot; -FilePath &quot;$(MSBuildProjectDirectory)\test.cpp&quot;" />
  </Target>
</Project>